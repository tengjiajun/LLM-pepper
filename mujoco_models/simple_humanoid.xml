<mujoco model="simple_humanoid">
  <compiler angle="radian" coordinate="local" inertiafromgeom="true"/>
  <option timestep="0.005" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <joint limited="true" damping="1" armature="0.01"/>
    <geom friction="1 0.5 0.01" density="300" rgba="0.8 0.8 0.85 1"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <worldbody>
    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.2 0.25 0.3 1"/>

    <body name="torso" pos="0 0 1.1">
      <freejoint/>
      <geom type="capsule" fromto="0 0 0.2 0 0 -0.2" size="0.12" rgba="0.9 0.9 0.95 1"/>

      <!-- head -->
      <body name="head" pos="0 0 0.35">
        <joint name="neck_pitch" type="hinge" axis="0 1 0" range="-0.6 0.6"/>
        <geom type="sphere" size="0.11" pos="0 0 0.05" rgba="0.95 0.85 0.8 1"/>
      </body>

      <!-- left arm -->
      <body name="l_shoulder" pos="0 0.18 0.22">
        <joint name="l_shoulder_pitch" type="hinge" axis="0 1 0" range="-1.2 1.2"/>
        <joint name="l_shoulder_roll" type="hinge" axis="1 0 0" range="-1.2 1.2"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.25" size="0.06"/>
        <body name="l_elbow" pos="0 0 -0.25">
          <joint name="l_elbow" type="hinge" axis="0 1 0" range="0 2.3"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.22" size="0.05"/>
        </body>
      </body>

      <!-- right arm -->
      <body name="r_shoulder" pos="0 -0.18 0.22">
        <joint name="r_shoulder_pitch" type="hinge" axis="0 1 0" range="-1.2 1.2"/>
        <joint name="r_shoulder_roll" type="hinge" axis="1 0 0" range="-1.2 1.2"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.25" size="0.06"/>
        <body name="r_elbow" pos="0 0 -0.25">
          <joint name="r_elbow" type="hinge" axis="0 1 0" range="0 2.3"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.22" size="0.05"/>
        </body>
      </body>

      <!-- left leg -->
      <body name="l_hip" pos="0 0.10 -0.20">
        <joint name="l_hip_pitch" type="hinge" axis="0 1 0" range="-1.2 1.2"/>
        <joint name="l_hip_roll" type="hinge" axis="1 0 0" range="-0.6 0.6"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.40" size="0.07"/>
        <body name="l_knee" pos="0 0 -0.40">
          <joint name="l_knee" type="hinge" axis="0 1 0" range="0 2.6"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.40" size="0.06"/>
          <body name="l_ankle" pos="0 0 -0.40">
            <joint name="l_ankle_pitch" type="hinge" axis="0 1 0" range="-0.8 0.8"/>
            <geom type="box" size="0.10 0.05 0.03" pos="0 0 -0.03" rgba="0.2 0.2 0.2 1"/>
          </body>
        </body>
      </body>

      <!-- right leg -->
      <body name="r_hip" pos="0 -0.10 -0.20">
        <joint name="r_hip_pitch" type="hinge" axis="0 1 0" range="-1.2 1.2"/>
        <joint name="r_hip_roll" type="hinge" axis="1 0 0" range="-0.6 0.6"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.40" size="0.07"/>
        <body name="r_knee" pos="0 0 -0.40">
          <joint name="r_knee" type="hinge" axis="0 1 0" range="0 2.6"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.40" size="0.06"/>
          <body name="r_ankle" pos="0 0 -0.40">
            <joint name="r_ankle_pitch" type="hinge" axis="0 1 0" range="-0.8 0.8"/>
            <geom type="box" size="0.10 0.05 0.03" pos="0 0 -0.03" rgba="0.2 0.2 0.2 1"/>
          </body>
        </body>
      </body>

    </body>
  </worldbody>

  <actuator>
    <!-- simple posture motors (unitless control) -->
    <motor joint="neck_pitch" gear="30"/>

    <motor joint="l_shoulder_pitch" gear="40"/>
    <motor joint="l_shoulder_roll" gear="40"/>
    <motor joint="l_elbow" gear="30"/>

    <motor joint="r_shoulder_pitch" gear="40"/>
    <motor joint="r_shoulder_roll" gear="40"/>
    <motor joint="r_elbow" gear="30"/>

    <motor joint="l_hip_pitch" gear="60"/>
    <motor joint="l_hip_roll" gear="60"/>
    <motor joint="l_knee" gear="60"/>
    <motor joint="l_ankle_pitch" gear="40"/>

    <motor joint="r_hip_pitch" gear="60"/>
    <motor joint="r_hip_roll" gear="60"/>
    <motor joint="r_knee" gear="60"/>
    <motor joint="r_ankle_pitch" gear="40"/>
  </actuator>
</mujoco>
